{% extends 'base.html.twig' %}

{% block title %}Repository Files{% endblock %}

{% block body %}
    <h1>Repository Files</h1>

    <div class="introduction mb-3">
        {{ 'files.intro'|trans }}
        {{ 'files.description'|trans|markdown_to_html }}
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <a class="btn btn-outline-secondary btn-sm mb-2" href="{{ path('app_load_files') }}">Reload Files</a>

            {% set _sc = '@survos/tree-bundle/tree' %}
            <div {{ stimulus_controller(_sc, {
                types: {
                    default: { icon: 'bi bi-folder2-open' },
                    dir: { icon: 'bi bi-folder2-open' },
                    file: { icon: 'bi bi-file-earmark' },
                    php: { icon: 'bi bi-filetype-php' },
                    json: { icon: 'bi bi-filetype-json' },
                    js: { icon: 'bi bi-filetype-js' },
                    yaml: { icon: 'bi bi-filetype-yaml' },
                    css: { icon: 'bi bi-filetype-css' }
                },
                plugins: ['search', 'sort', 'types']
            }) }}>
                <input
                        {{ stimulus_action(_sc, 'search') }}
                        type="search"
                        class="form-control form-control-sm mb-2"
                        placeholder="Search files"
                />

                <div {{ stimulus_target(_sc, 'html') }}>
                    {% tree e in entities %}
                        {% if treeloop.first %}<ul>{% endif %}
                        <li
                                data-path="{{ e.path }}"
                                data-type="{{ e.isDir ? 'dir' : 'file' }}"
                                data-jstree='{"path": "{{ e.path }}", "type":"{{ e.isDir ? 'dir' : e.extension }}"}'>
                            {{ e.name }}
                            {% subtree e.children %}
                        </li>
                        {% if treeloop.last %}</ul>{% endif %}
                    {% endtree %}
                </div>
            </div>
        </div>

        <div class="col-md-8">
            {% set _sc = 'file_browser' %}
            <div {{ stimulus_controller(_sc, { sourcePath: path('app_file_source') }) }}>
                <h3 {{ stimulus_target(_sc, 'title') }}>Select a file</h3>
                <pre class="border rounded p-3 bg-white" {{ stimulus_target(_sc, 'content') }}>File contents will appear here.</pre>
            </div>
        </div>
    </div>
{% endblock %}
