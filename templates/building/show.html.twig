{% extends 'base.html.twig' %}

{% block title %}Building: {{ building.name }}{% endblock %}

{% block body %}
    <h1>{{ building.name }}</h1>

    <div class="row g-3">
        <div class="col-md-5">
            <h3>Locations Tree</h3>
            {% component api_tree with {
                apiUrl: apiUrl,
                class: 'App\\Entity\\Location',
                filter: filter
            } %}
            {% endcomponent %}
        </div>

        <div class="col-md-7">
            <div {{ stimulus_controller('topic') }}>
                <h3 {{ stimulus_target('topic', 'title') }}>Selection</h3>
                <pre class="border rounded p-3 bg-white" {{ stimulus_target('topic', 'results') }}>Select a location node.</pre>
            </div>

            <table class="table mt-3">
                <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ building.id }}</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>{{ building.name }}</td>
                </tr>
                </tbody>
            </table>

            <a href="{{ path('building_edit', building.rp) }}">Edit building</a>
            {{ include('building/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
