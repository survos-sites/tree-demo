{% extends 'base.html.twig' %}

{% block title %}Basic HTML Demo{% endblock %}

{% block javascripts %}
{{ parent() }}
{% endblock %}


{% block body %}

    <h1>Survos Tree Bundle</h1>
    See https://stackoverflow.com/questions/8326482/how-to-render-a-tree-in-twig for the solution using macros
    {% set food = [
        {name: 'fruit', children: [
            {name: 'apple', children: [
                {name: 'Granny Smith'},
                {name: 'Gala'},
                {name: 'Fuji'},
            ]},
            {name: 'banana'}
        ]},
        {name: 'veggies', children: [
            {name: 'peas'},
            {name: 'carrots'},
            {name: 'beets'}
        ]},

    ] %}


<h1>Food Tree</h1>
{% set _sc = '@survos/tree-bundle/tree' %}

<style>
    .tree-demo-grid .card { height: 100%; }
    .tree-demo-grid .card-body { max-height: 420px; overflow: auto; }
    .tree-debug-log { min-height: 120px; white-space: pre-wrap; }
</style>

<div class="row g-3 tree-demo-grid">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><strong>1) Twig Tree Tag Only</strong></div>
            <div class="card-body">
                {{ block('food_tree') }}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><strong>2) Stimulus Tree (Toggle + Events)</strong></div>
            <div class="card-body">
                <div id="tree-test" {{ stimulus_controller(_sc) }} {{ stimulus_target(_sc, 'html') }}>
                    {{ block('food_tree') }}
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><strong>3) Stimulus Tree + Checkbox + Search</strong></div>
            <div class="card-body">
                <input
                    class="form-control form-control-sm mb-2"
                    placeholder="Search nodes"
                    {{ stimulus_action(_sc, 'search', 'input') }}
                />
                <div
                    id="tree-checkbox"
                    {{ stimulus_controller(_sc, { checkboxes: true, plugins: ['checkbox'] }) }}
                    {{ stimulus_target(_sc, 'html') }}
                >
                    {{ block('food_tree') }}
                </div>
            </div>
        </div>
    </div>
</div>

<h3 class="mt-4">Event Log</h3>
<pre id="tree-debug-log" class="tree-debug-log border rounded p-2">Listening for jstree/apitree_changed...</pre>

<script type="module">
    const log = document.getElementById('tree-debug-log');
    const write = (label, detail) => {
        const line = `[${new Date().toLocaleTimeString()}] ${label} ${JSON.stringify(detail)}`;
        console.debug(line);
        if (log) {
            log.textContent = `${line}\n${log.textContent}`;
        }
    };
    window.addEventListener('jstree', (event) => write('jstree', event.detail));
    window.addEventListener('apitree_changed', (event) => write('apitree_changed', event.detail));
    window.addEventListener('jstree.ready', (event) => write('jstree.ready', event.detail));
</script>


    <h2>A Stimulus Controller</h2>
    <div>
        At the most basic level, you can turn any tree into a dynamic tree by using the stimulus controller. It gives developers a very fast way to implement it. It requires you already have an unordered
        list. In this case, we're just copying from the jstree documentation.
    </div>
    {{ component('divider') }}

    <h2>{{ 'gedmo-tree.title'|trans }}</h2>
    <div>
        {{ 'gedmo-tree.intro'|trans }}
    </div>
    {{ component('divider') }}

{% endblock %}

    {% block food_tree %}
    {% tree item in food %}
        {% if treeloop.first %}<ul>{% endif %}
        <li>
            {{ item.name }}
            {% subtree item.children|default([]) %}
        </li>
        {% if treeloop.last %}</ul>{% endif %}
    {% endtree %}
{% endblock %}

