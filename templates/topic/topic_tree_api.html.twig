{% extends 'layout.html.twig' %}

{% block title %}Topics (API Tree){% endblock %}

{% block body %}
    <h1>Topics (API Tree)</h1>

    <twig:apiTreeBrowser
        :resourceClass="topicClass"
        :filter="filter|default({})"
        :editable="true"
        :openAll="true"
        :selectFirst="false"
        :caller="_self"
    >
        <twig:block name="nodeLabel">
            LABEL
            {{ node.name ?? node.title ?? node.code ?? node.id }}
            <small class="text-muted">({{ node.childCount ?? 0 }})</small>
        </twig:block>

        <twig:block name="api_tree_content">
            api_tree_content
            {% set item = record ?? node %}
            <div class="fw-semibold">{{ item.name ?? item.title ?? item.code ?? item.id }}</div>
            <div class="small text-muted">Code: {{ item.code ?? '—' }}</div>
            <div class="small text-muted">Children: {{ item.childCount ?? 0 }}</div>
            {% if item.description is defined and item.description %}
                <div class="mt-2 small">{{ item.description }}</div>
            {% endif %}
        </twig:block>
    </twig:apiTreeBrowser>
{% endblock %}
